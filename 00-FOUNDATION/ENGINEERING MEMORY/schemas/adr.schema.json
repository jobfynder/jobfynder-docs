{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Jobfynder Architecture Decision Record",
  "type": "object",
  "required": [
    "id",
    "title",
    "status",
    "date",
    "repository",
    "authors",
    "context",
    "decision",
    "consequences"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique ADR identifier (e.g. ADR-0024)"
    },
    "title": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "accepted",
        "deprecated",
        "superseded",
        "rejected"
      ]
    },
    "date": {
      "type": "string",
      "description": "YYYY-MM-DD"
    },
    "repository": {
      "type": "string"
    },
    "authors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "context": {
      "type": "string",
      "description": "Background and problem being solved."
    },
    "decision": {
      "type": "string",
      "description": "The architectural decision."
    },
    "alternatives_considered": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "reason"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "consequences": {
      "type": "object",
      "required": [
        "positive",
        "negative"
      ],
      "properties": {
        "positive": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "negative": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "affected_components": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related_adrs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "implementation_notes": {
      "type": "string"
    },
    "review_date": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
    "confidence": {
  "type": "string",
  "enum": [
    "experimental",
    "high",
    "proven"
  ]
      }
    }
  }
}